{
  "name": "claudewatch",
  "private": true,
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "build": "npm run build:extension && npm run build:hooks && npm run copy:assets",
    "build:extension": "tsc -p tsconfig.extension.json",
    "build:hooks": "tsc -p tsconfig.hooks.json",
    "copy:assets": "node scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.extension.json --noEmit && tsc -p tsconfig.hooks.json --noEmit && tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@girs/gjs": "4.1.0",
    "@girs/gnome-shell": "46.0.2",
    "@girs/pango-1.0": "4.1.0",
    "@girs/soup-3.0": "4.1.0",
    "@types/node": "^22.13.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@girs/gio-2.0": "4.1.0",
    "@girs/glib-2.0": "4.1.0",
    "@girs/gobject-2.0": "4.1.0"
  }
}
